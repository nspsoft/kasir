{
  "name": "kasir-backend",
  "version": "0.1.0",
  "description": "Backend API untuk Aplikasi Kasir",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.js\"",
    "build": "echo \"No build needed for Node.js backend\"",
    "start:prod": "NODE_ENV=production node server.js"
  },
  "keywords": [
    "kasir",
    "pos",
    "point-of-sale",
    "penjualan"
  ],
  "author": "NSP Software",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "dotenv": "^16.3.1",
    "pg": "^8.11.1",
    "sequelize": "^6.33.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.1.0",
    "joi": "^17.10.2",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "axios": "^1.5.0",
    "uuid": "^9.0.0",
    "date-fns": "^2.30.0",
    "lodash": "^4.17.21",
    "express-validator": "^7.0.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.6",
    "redis": "^4.6.10",
    "swagger-ui-express": "^5.0.0",
    "swagger-jsdoc": "^6.2.8"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.50.0",
    "prettier": "^3.0.3",
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "babel-jest": "^29.7.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
