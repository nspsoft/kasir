# Global .gitignore for Kasir Project

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.iml

# Build output
dist/
build/
out/
*.tsbuildinfo

# Logs
logs/
*.log

# Coverage
coverage/
.nyc_output/

# Testing
.pytest_cache/
__pycache__/

# Temporary files
tmp/
temp/
*.tmp

# OS files
.DS_Store
.env.*.local
Thumbs.db

# Database
*.db
*.sqlite
*.sqlite3
*.sql.bak

# Docker
.docker/
docker-compose.override.yml

# Production builds
/frontend/dist
/frontend/build

# Cache
.eslintcache
.cache
